@model List<Soru>

@{
    ViewBag.Title = "Sınav";
}

<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" />

<form method="post" asp-action="SinavBitir" class="container mt-3">

    <!-- SINAV ID -->
    <input type="hidden" name="sinavId" value="@ViewBag.SinavId" />

    @if (Model != null && Model.Any())
    {
        int index = 1;

        foreach (var s in Model)
        {
            <div class="card mb-3 shadow-sm">

                <!-- SORU BAŞLIK -->
                <div class="card-header bg-light">
                    <b>@index)</b> @s.SoruMetni
                </div>

                <!-- ŞIKLAR -->
                <div class="card-body">

                    <div class="form-check">
                        <input class="form-check-input"
                               type="radio"
                               name="cevap_@s.SoruId"
                               value="A"
                               id="a_@s.SoruId" />
                        <label class="form-check-label" for="a_@s.SoruId">
                            A) @s.SecenekA
                        </label>
                    </div>

                    <div class="form-check">
                        <input class="form-check-input"
                               type="radio"
                               name="cevap_@s.SoruId"
                               value="B"
                               id="b_@s.SoruId" />
                        <label class="form-check-label" for="b_@s.SoruId">
                            B) @s.SecenekB
                        </label>
                    </div>

                    <div class="form-check">
                        <input class="form-check-input"
                               type="radio"
                               name="cevap_@s.SoruId"
                               value="C"
                               id="c_@s.SoruId" />
                        <label class="form-check-label" for="c_@s.SoruId">
                            C) @s.SecenekC
                        </label>
                    </div>

                    <div class="form-check">
                        <input class="form-check-input"
                               type="radio"
                               name="cevap_@s.SoruId"
                               value="D"
                               id="d_@s.SoruId" />
                        <label class="form-check-label" for="d_@s.SoruId">
                            D) @s.SecenekD
                        </label>
                    </div>

                </div>

            </div>

            index++;
        }

        <button type="submit" class="btn btn-success w-100 mt-3">
            🧾 Sınavı Bitir
        </button>
    }
    else
    {
        <div class="alert alert-warning text-center">
            Soru bulunamadı
        </div>
    }

</form>