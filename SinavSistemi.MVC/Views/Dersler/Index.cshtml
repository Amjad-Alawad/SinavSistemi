@model List<DersVM>
@{
    ViewData["Title"] = "Dersler";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h4 class="fw-bold mb-0"><i class="bi bi-book me-2"></i>Dersler</h4>
    <a href="/Dersler/Ekle" class="btn btn-primary"><i class="bi bi-plus-circle me-1"></i>Yeni Ders</a>
</div>

<div class="card">
    <div class="card-body p-0">
        <table class="table table-hover mb-0">
            <thead>
                <tr>
                    <th>#</th>
                    <th>Ders Adı</th>
                    <th>Hoca</th>
                    <th>Öğrenci</th>
                    <th>İşlemler</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var d in Model)
                {
                    <tr>
                        <td class="text-muted">@d.DersId</td>
                        <td class="fw-semibold">@d.DersAdi</td>
                        <td>@d.HocaAd</td>
                        <td><span class="badge bg-info text-dark">@d.OgrenciSayisi öğrenci</span></td>
                        <td>
                            <a href="/Dersler/Duzenle/@d.DersId" class="btn btn-sm btn-outline-warning">
                                <i class="bi bi-pencil"></i> Düzenle
                            </a>
                            <form method="post" action="/Dersler/Sil/@d.DersId" style="display:inline"
                                    onsubmit="return confirm('@d.DersAdi silinsin mi?')">
                                <button type="submit" class="btn btn-sm btn-outline-danger">
                                    <i class="bi bi-trash"></i> Sil
                                </button>
                            </form>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>