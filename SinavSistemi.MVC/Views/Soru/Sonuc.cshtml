@{
    ViewData["Title"] = "Sınav Sonucu";
}

<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" />

<div class="container mt-5">

    <div class="card shadow p-4 text-center">

        <h2>📊 Sınav Sonucu</h2>

        <div class="row mt-4">

            <div class="col-md-4">
                <div class="alert alert-success">
                    <h4>Doğru</h4>
                    <h2>@ViewBag.Dogru</h2>
                </div>
            </div>

            <div class="col-md-4">
                <div class="alert alert-danger">
                    <h4>Yanlış</h4>
                    <h2>@ViewBag.Yanlis</h2>
                </div>
            </div>

            <div class="col-md-4">
                <div class="alert alert-primary">
                    <h4>Puan</h4>
                    <h2>@ViewBag.Puan</h2>
                </div>
            </div>

        </div>

        <hr />

        @if ((int)ViewBag.Puan >= 50)
        {
            <h3 class="text-success">✔ Geçtiniz</h3>
        }
        else
        {
            <h3 class="text-danger">❌ Kaldınız</h3>
        }

        <a href="/Soru/Index" class="btn btn-dark mt-3">
            Geri Dön
        </a>

    </div>

</div>