@model SalonVM
@{
    ViewData["Title"] = "Salon Düzenle";
}

<div class="d-flex align-items-center mb-4">
    <a href="/Salonlar" class="btn btn-outline-secondary me-3"><i class="bi bi-arrow-left"></i></a>
    <h4 class="fw-bold mb-0">Salon Düzenle</h4>
</div>

<div class="card" style="max-width:480px">
    <div class="card-body">
        @if (ViewBag.Hata != null)
        {
            <div class="alert alert-danger">@ViewBag.Hata</div>
        }
        <form method="post">
            <input type="hidden" name="SalonId" value="@Model.SalonId" />
            <div class="mb-3">
                <label class="form-label fw-semibold">Salon Adı</label>
                <input name="SalonAdi" value="@Model.SalonAdi" class="form-control" required />
            </div>
            <div class="mb-3">
                <label class="form-label fw-semibold">Kapasite</label>
                <input name="Kapasite" value="@Model.Kapasite" type="number" min="1" class="form-control" required />
            </div>
            <button type="submit" class="btn btn-warning w-100">
                <i class="bi bi-check-circle me-1"></i>Güncelle
            </button>
        </form>
    </div>
</div>