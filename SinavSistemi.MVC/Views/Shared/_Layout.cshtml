<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Sınav Sistemi</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.5/font/bootstrap-icons.css" rel="stylesheet" />
    <style>
        body { background-color: #f4f6f9; }
        .sidebar { min-height: 100vh; background-color: #1e2a38; position: fixed; width: 220px; }
        .sidebar-brand { padding: 20px; color: white; text-align: center; border-bottom: 1px solid #2e3f52; }
        .sidebar .nav-link { color: #9ba8b5; padding: 10px 20px; display: block; text-decoration: none; }
        .sidebar .nav-link:hover { color: #fff; background-color: #2e3f52; }
        .sidebar .nav-link.active { color: #fff; background-color: #0d6efd; border-radius: 5px; margin: 0 10px; }
        .sidebar .nav-section { color: #5a6a7a; font-size: 11px; text-transform: uppercase; padding: 15px 20px 5px; }
        .main { margin-left: 220px; padding: 30px; }
        .card { border: none; box-shadow: 0 1px 6px rgba(0,0,0,0.08); border-radius: 10px; }
        .table thead th { background-color: #f1f3f5; font-weight: 600; border-bottom: 2px solid #dee2e6; }
        .stat-card { border-radius: 12px; color: white; padding: 25px; }
        .stat-card .sayi { font-size: 2rem; font-weight: 700; }
        .stat-card .etiket { font-size: 14px; opacity: 0.9; }
    </style>
</head>
<body>

    <div class="sidebar">
        <div class="sidebar-brand">
            <i class="bi bi-mortarboard-fill fs-3"></i>
            <div class="fw-bold mt-1" style="font-size:15px">Sınav Sistemi</div>
        </div>
        <nav class="mt-3">
            <div class="nav-section">Ana Menü</div>
            <a href="@Url.Action("Index", "Home")" class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Home" ? "active" : "")">
                <i class="bi bi-house me-2"></i>Ana Sayfa
            </a>

            <div class="nav-section mt-2">Yönetim</div>
            <a href="@Url.Action("Index", "Hocalar")" class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Hocalar" ? "active" : "")">
                <i class="bi bi-person-badge me-2"></i>Hocalar
            </a>
            <a href="@Url.Action("Index", "Ogrenciler")" class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Ogrenciler" ? "active" : "")">
                <i class="bi bi-people me-2"></i>Öğrenciler
            </a>
            <a href="@Url.Action("Index", "Dersler")" class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Dersler" ? "active" : "")">
                <i class="bi bi-book me-2"></i>Dersler
            </a>
            <a href="@Url.Action("Index", "Salonlar")" class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Salonlar" ? "active" : "")">
                <i class="bi bi-door-open me-2"></i>Salonlar
            </a>
            <a href="@Url.Action("Index", "Sinavlar")" class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Sinavlar" ? "active" : "")">
                <i class="bi bi-clipboard-check me-2"></i>Sınavlar
            </a>
            <a href="@Url.Action("Index", "Soru")" class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Soru" ? "active" : "")">
                <i class="bi bi-question-circle me-2"></i>Sorular
            </a>
            <a href="@Url.Action("Index", "Rapor")"
               class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Rapor" ? "active" : "")">
                <i class="bi bi-graph-up me-2"></i>Raporlar
            </a>

            <div style="position:absolute; bottom:20px; width:100%; padding:0 15px;">
                <a href="@Url.Action("Cikis", "Auth")" class="btn btn-outline-danger w-100">
                    <i class="bi bi-box-arrow-left me-2"></i>Çıkış Yap
                </a>
            </div>
        </nav>
    </div>

    <div class="main">
        @if (TempData["Hata"] != null)
        {
            <div class="alert alert-danger alert-dismissible fade show">
                @TempData["Hata"]
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
        }
        @if (TempData["Basarili"] != null)
        {
            <div class="alert alert-success alert-dismissible fade show">
                @TempData["Basarili"]
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
        }
        @RenderBody()
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>