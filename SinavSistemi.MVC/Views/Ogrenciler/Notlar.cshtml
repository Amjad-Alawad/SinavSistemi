@model List<OgrenciSinaviVM>

@{
    ViewData["Title"] = "Öğrenci Notları";
}

<div class="d-flex align-items-center mb-4">
    <a href="/Ogrenciler" class="btn btn-outline-secondary me-3">
        <i class="bi bi-arrow-left"></i>
    </a>
    <h4 class="fw-bold mb-0">
        <i class="bi bi-bar-chart me-2"></i>
        @ViewBag.OgrenciAdi — Notlar
    </h4>
</div>

<div class="card">
    <div class="card-body p-0">

        @if (Model == null || !Model.Any())
        {
            <div class="alert alert-warning text-center m-3">
                Bu öğrenciye ait sınav / not bulunamadı.
            </div>
        }
        else
        {
            <table class="table table-hover mb-0">
                <thead>
                    <tr>
                        <th>Ders</th>
                        <th>Hoca</th>
                        <th>Salon</th>
                        <th>Tarih</th>
                        <th>Saat</th>
                        <th>Not</th>
                    </tr>
                </thead>

                <tbody>
                    @foreach (var s in Model)
                    {
                        <tr>
                            <td>@s.DersAdi</td>
                            <td>@s.HocaAdi</td>
                            <td>@s.SalonAdi</td>

                            <td>
                                @Convert.ToDateTime(s.SinavTarihi).ToString("dd.MM.yyyy")
                            </td>

                            <td>
                                @s.BaslangicSaati - @s.BitisSaati
                            </td>

                            <td>
                                @if (s.Notu.HasValue)
                                {
                                    <span class="badge @(s.Notu >= 50 ? "bg-success" : "bg-danger")">
                                        @s.Notu
                                    </span>
                                }
                                else
                                {
                                    <span class="badge bg-secondary">Girilmedi</span>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        }
    </div>
</div>