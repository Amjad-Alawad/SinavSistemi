@model List<SalonVM>
@{
    ViewData["Title"] = "Salonlar";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h4 class="fw-bold mb-0"><i class="bi bi-door-open me-2"></i>Salonlar</h4>
    <a href="/Salonlar/Ekle" class="btn btn-primary"><i class="bi bi-plus-circle me-1"></i>Yeni Salon</a>
</div>

<div class="card">
    <div class="card-body p-0">
        <table class="table table-hover mb-0">
            <thead>
                <tr>
                    <th>#</th>
                    <th>Salon Adı</th>
                    <th>Kapasite</th>
                    <th>İşlemler</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var s in Model)
                {
                    <tr>
                        <td class="text-muted">@s.SalonId</td>
                        <td class="fw-semibold">@s.SalonAdi</td>
                        <td><span class="badge bg-secondary">@s.Kapasite kişi</span></td>
                        <td>
                            <a href="/Salonlar/Duzenle/@s.SalonId" class="btn btn-sm btn-outline-warning">
                                <i class="bi bi-pencil"></i> Düzenle
                            </a>
                            <form method="post" action="/Salonlar/Sil/@s.SalonId" style="display:inline"
                                  onsubmit="return confirm('@s.SalonAdi silinsin mi?')">
                                <button type="submit" class="btn btn-sm btn-outline-danger">
                                    <i class="bi bi-trash"></i> Sil
                                </button>
                            </form>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>