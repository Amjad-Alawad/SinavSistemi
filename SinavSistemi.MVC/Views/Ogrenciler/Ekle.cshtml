@{
    ViewData["Title"] = "Öğrenci Ekle";
}

<div class="d-flex align-items-center mb-4">
    <a href="/Ogrenciler" class="btn btn-outline-secondary me-3"><i class="bi bi-arrow-left"></i></a>
    <h4 class="fw-bold mb-0">Yeni Öğrenci Ekle</h4>
</div>

<div class="card" style="max-width:480px">
    <div class="card-body">
        @if (ViewBag.Hata != null)
        {
            <div class="alert alert-danger">@ViewBag.Hata</div>
        }
        <form method="post">
            <div class="mb-3">
                <label class="form-label fw-semibold">Öğrenci No</label>
                <input name="OgrenciNo" class="form-control" placeholder="Örn: 2021001" required />
            </div>
            <div class="mb-3">
                <label class="form-label fw-semibold">Ad</label>
                <input name="Ad" class="form-control" required />
            </div>
            <div class="mb-3">
                <label class="form-label fw-semibold">Soyad</label>
                <input name="Soyad" class="form-control" required />
            </div>
            <button type="submit" class="btn btn-primary w-100">
                <i class="bi bi-check-circle me-1"></i>Kaydet
            </button>
        </form>
    </div>
</div>