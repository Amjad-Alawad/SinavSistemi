@model List<OgrenciSinaviVM>
@{
    ViewData["Title"] = "Sınav Detayı";
}

<div class="d-flex align-items-center mb-4">
    <a href="/Sinavlar" class="btn btn-outline-secondary me-3"><i class="bi bi-arrow-left"></i></a>
    <h4 class="fw-bold mb-0"><i class="bi bi-eye me-2"></i>@ViewBag.SinavBilgi</h4>
</div>

<div class="card">
    <div class="card-body p-0">
        <table class="table table-hover mb-0">
            <thead>
                <tr>
                    <th>Öğrenci No</th>
                    <th>Ad Soyad</th>
                    <th>Not</th>
                </tr>
            </thead>
            <tbody>
                @if (!Model.Any())
                {
                    <tr><td colspan="3" class="text-center text-muted py-3">Henüz öğrenci eklenmedi.</td></tr>
                }
                @foreach (var o in Model)
                {
                    <tr>
                        <td><span class="badge bg-dark">@o.OgrenciNo</span></td>
                        <td>@o.OgrenciAdi</td>
                        <td>
                            @if (o.Notu.HasValue)
                            {
                                <span class="badge @(o.Notu >= 50 ? "bg-success" : "bg-danger")">@o.Notu</span>
                            }
                            else
                            {
                                <span class="badge bg-secondary">Girilmedi</span>
                            }
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>