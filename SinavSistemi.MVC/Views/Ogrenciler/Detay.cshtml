@model OgrenciDetayVM
@{
    ViewData["Title"] = "Öğrenci Detay";
}
<div class="d-flex align-items-center mb-4">
    <a href="@Url.Action("Index", "Ogrenciler")" class="btn btn-outline-secondary me-3">
        <i class="bi bi-arrow-left"></i>
    </a>
    <h4 class="fw-bold mb-0 me-auto">
        <i class="bi bi-person-circle me-2"></i>@Model.Ad @Model.Soyad
    </h4>
    <a href="@Url.Action("PdfIndir", "Ogrenciler", new { id = Model.OgrenciId })"
       class="btn btn-danger">
        <i class="bi bi-file-pdf me-2"></i>PDF İndir
    </a>
</div>


<!-- Öğrenci Bilgi Kartı -->
<div class="row g-3 mb-4">
    <div class="col-md-3">
        <div class="card text-center p-3">
            <div class="text-muted small mb-1">Öğrenci No</div>
            <div class="fw-bold fs-5">@Model.OgrenciNo</div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card text-center p-3">
            <div class="text-muted small mb-1">Kayıtlı Ders</div>
            <div class="fw-bold fs-5 text-primary">@Model.DersSayisi</div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card text-center p-3">
            <div class="text-muted small mb-1">Toplam Sınav</div>
            <div class="fw-bold fs-5 text-info">@Model.SinavSayisi</div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card text-center p-3">
            <div class="text-muted small mb-1">Genel Ortalama</div>
            <div class="fw-bold fs-5 @(Model.Ortalama >= 50 ? "text-success" : "text-danger")">
                @Model.Ortalama.ToString("F1")
            </div>
        </div>
    </div>
</div>

<!-- Geçme / Kalma Özeti -->
<div class="row g-3 mb-4">
    <div class="col-md-6">
        <div class="card p-3" style="border-left: 4px solid #198754;">
            <div class="d-flex justify-content-between align-items-center">
                <div>
                    <div class="text-muted small">Geçilen Sınav</div>
                    <div class="fw-bold fs-4 text-success">@Model.GecenSayisi</div>
                </div>
                <i class="bi bi-check-circle-fill text-success fs-1 opacity-25"></i>
            </div>
        </div>
    </div>
    <div class="col-md-6">
        <div class="card p-3" style="border-left: 4px solid #dc3545;">
            <div class="d-flex justify-content-between align-items-center">
                <div>
                    <div class="text-muted small">Kalan Sınav</div>
                    <div class="fw-bold fs-4 text-danger">@Model.KalanSayisi</div>
                </div>
                <i class="bi bi-x-circle-fill text-danger fs-1 opacity-25"></i>
            </div>
        </div>
    </div>
</div>

<!-- Sınav Listesi -->
<div class="card">
    <div class="card-header bg-white fw-semibold py-3">
        <i class="bi bi-clipboard-check me-2 text-primary"></i>Sınav Geçmişi
    </div>
    <div class="card-body p-0">
        <table class="table table-hover mb-0">
            <thead>
                <tr>
                    <th>Ders</th>
                    <th>Hoca</th>
                    <th>Salon</th>
                    <th>Tarih</th>
                    <th>Saat</th>
                    <th>Not</th>
                    <th>Durum</th>
                </tr>
            </thead>
            <tbody>
                @if (!Model.Sinavlar.Any())
                {
                    <tr>
                        <td colspan="7" class="text-center text-muted py-4">
                            Henüz sınav kaydı bulunmamaktadır.
                        </td>
                    </tr>
                }
                @foreach (var s in Model.Sinavlar)
                {
                    <tr>
                        <td class="fw-semibold">@s.DersAdi</td>
                        <td>@s.HocaAdi</td>
                        <td>@s.SalonAdi</td>
                        <td>@s.SinavTarihi</td>
                        <td>@s.BaslangicSaati</td>
                        <td>
                            @if (s.Notu.HasValue)
                            {
                                <span class="badge @(s.Notu >= 50 ? "bg-success" : "bg-danger") px-2 py-1">
                                    @s.Notu
                                </span>
                            }
                            else
                            {
                                <span class="badge bg-secondary px-2 py-1">Girilmedi</span>
                            }
                        </td>
                        <td>
                            @if (!s.Notu.HasValue)
                            {
                                <span class="badge bg-warning text-dark">Bekliyor</span>
                            }
                            else if (s.Notu >= 50)
                            {
                                <span class="badge bg-success">
                                    <i class="bi bi-check me-1"></i>Geçti
                                </span>
                            }
                            else
                            {
                                <span class="badge bg-danger">
                                    <i class="bi bi-x me-1"></i>Kaldı
                                </span>
                            }
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
    @if (Model.Sinavlar.Any(s => s.Notu.HasValue))
    {
        <div class="card-footer bg-light text-end">
            <strong>Genel Ortalama:</strong>
            <span class="badge @(Model.Ortalama >= 50 ? "bg-success" : "bg-danger") ms-2 px-3 py-2 fs-6">
                @Model.Ortalama.ToString("F1")
            </span>
        </div>
    }
</div>